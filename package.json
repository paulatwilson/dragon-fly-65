{
  "name": "dragon-fly-65",
  "version": "0.1.0",
  "description": "A hypothetical W65C832-based computer and operating system written in TypeScript for Bun.",
  "type": "module",
  "private": false,
  "exports": {
    "./emulator": "./src/emulator/index.ts",
    "./assembler": "./src/assembler/index.ts",
    "./compiler": "./src/compiler/index.ts"
  },
  "license": "GPL-3.0-only",
  "author": "Paul Wilson",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/paulwilson/dragon-fly-65.git"
  },
  "bugs": {
    "url": "https://github.com/paulwilson/dragon-fly-65/issues"
  },
  "homepage": "https://github.com/paulwilson/dragon-fly-65#readme",
  "keywords": [
    "bun",
    "typescript",
    "w65c832",
    "retrocomputing",
    "operating-system",
    "ssh",
    "fly.io"
  ],
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch src/index.ts",
    "asm": "bun run src/assembler/cli.ts",
    "lace": "bun run src/compiler/cli.ts",
    "lace:monitor": "bun run scripts/run-lovelace-monitor.ts",
    "monitor": "bun run src/monitor/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "latest"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
